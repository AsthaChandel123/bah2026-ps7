# --- Python bytecode / caches --------------------------------------------- #
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Packaging / build artifacts ------------------------------------------ #
build/
dist/
*.egg-info/
.eggs/
wheels/
*.egg
pip-wheel-metadata/

# --- Virtual environments ------------------------------------------------- #
.venv/
venv/
env/
ENV/
.python-version

# --- Test / type / lint caches -------------------------------------------- #
.pytest_cache/
.cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Pipeline caches & data (keep configs/ and tests/) -------------------- #
# NOTE: runtime-output dirs are ROOT-ANCHORED (leading /) so they only match
# repo-root output dirs and never shadow source/example dirs such as
# src/exopipe/data/ or examples/.
.cache/
/data/
/outputs/
/runs/
*.parquet
*.zarr/
*.h5
*.hdf5
*.fits
*.npy
*.npz
*.joblib
*.pkl

# --- Notebooks / editors / OS --------------------------------------------- #
.ipynb_checkpoints/
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Logs ----------------------------------------------------------------- #
*.log

# --- Allow curated example artifacts to be committed ---------------------- #
# Placed AFTER the glob patterns above (*.parquet, *.fits, *.png, ...) so these
# negations win and a curated examples/ , report/ , docs/ tree can hold
# committed artifacts later.
!examples/**
!report/**
!docs/**

# --- Ship the one trained classifier the pipeline loads ------------------- #
# `*.joblib` above ignores all model blobs; negate the single committed model
# (a few MB) so `ensemble.load_models("models")` finds it on a fresh checkout.
!models/exopipe_clf.joblib
